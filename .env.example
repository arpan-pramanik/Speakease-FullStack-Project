# Environment Variables Example Template

# This file serves as a reference for the required environment variables.
# Copy this file to .env in the respective directories and fill in your values.

# --- SERVER CONFIGURATION (.env in /server) ---
PORT=5000
MONGO_URI=mongodb://localhost:27017/speakease
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRE=30d

# OAuth Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# AI Configuration
MISTRAL_API_KEY=your_mistral_api_key

# --- CLIENT CONFIGURATION (.env in /client) ---
VITE_MISTRAL_API_KEY=your_mistral_api_key
